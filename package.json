{
  "name": "oraculo-loguin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fast": "node scripts/fast-dev.js",
    "dev:basic": "NEXT_TELEMETRY_DISABLED=1 next dev --port 3000",
    "dev:stable": "NEXT_TELEMETRY_DISABLED=1 next dev --port 3000",
    "dev:3000": "node scripts/setup-env.js 3000 && next dev -p 3000",
    "dev:3001": "node scripts/setup-env.js 3001 && next dev -p 3001",
    "dev:3002": "node scripts/setup-env.js 3002 && next dev -p 3002",
    "dev:3003": "node scripts/setup-env.js 3003 && next dev -p 3003",
    "devtools": "react-devtools",
    "devtools:setup": "node scripts/setup-devtools.js",
    "devtools:launch": "node scripts/setup-devtools.js --launch",
    "dev:with-devtools": "concurrently \"npm run dev\" \"npm run devtools\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:backup": "node scripts/backup-database.js",
    "db:backup-complete": "node scripts/backup-complete.js",
    "db:restore": "node scripts/restore-database.js",
    "db:restore-safe": "node scripts/restore-safe.js",
    "db:safe-reset": "node scripts/safe-reset.js",
    "db:add-pwa": "node scripts/run-custom-migration.js",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.js",
    "test-pwa": "node scripts/test-pwa.js",
    "setup-env": "node scripts/setup-env.js",
    "test:performance": "node scripts/performance-test.js",
    "test:perf": "npm run test:performance",
    "db:diagnose": "node scripts/diagnostic-postgresql.js",
    "db:monitor": "node scripts/monitor-postgresql.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed-oraculo.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@tiptap/extension-code-block-lowlight": "^3.6.6",
    "@tiptap/extension-image": "^3.6.6",
    "@tiptap/extension-link": "^3.6.6",
    "@tiptap/extension-placeholder": "^3.6.6",
    "@tiptap/react": "^3.6.6",
    "@tiptap/starter-kit": "^3.6.6",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "@uploadthing/react": "^7.3.3",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "framer-motion": "^12.23.22",
    "jsonwebtoken": "^9.0.2",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.544.0",
    "mercadopago": "^2.9.0",
    "next": "14.0.4",
    "next-auth": "^4.24.5",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.10.1",
    "react": "^18",
    "react-countup": "^6.5.3",
    "react-dom": "^18",
    "react-hook-form": "^7.48.2",
    "react-intersection-observer": "^9.16.0",
    "recharts": "^3.2.1",
    "stripe": "^18.5.0",
    "tailwind-merge": "^2.0.0",
    "uploadthing": "^7.7.4",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.20",
    "@types/react": "^18",
    "@types/react-devtools": "^3.6.2",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "canvas": "^3.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "postcss": "^8",
    "prisma": "^5.7.1",
    "react-devtools": "^7.0.0",
    "sharp": "^0.34.4",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
