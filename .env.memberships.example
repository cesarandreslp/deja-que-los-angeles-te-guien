# ===========================================
# CONFIGURACIÓN DE MEMBRESÍAS - PHASE 5
# ===========================================

# Seguridad para Cron Jobs
CRON_SECRET=your-super-secure-cron-secret-key-here
ADMIN_SECRET=your-admin-dashboard-secret-key-here

# Configuración de Notificaciones por Email
# Configura según tu proveedor de email preferido

# SendGrid (recomendado)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Nodemailer SMTP (alternativo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Configuración de Webhooks
WEBHOOK_TIMEOUT=30000  # 30 segundos

# URLs de la aplicación
NEXTAUTH_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ===========================================
# CONFIGURACIÓN DE CRON JOBS
# ===========================================

# Para configurar en tu servidor de producción:
# 
# 1. Expiración de suscripciones (diario a las 2:00 AM)
# 0 2 * * * curl -X POST -H "Authorization: Bearer ${CRON_SECRET}" ${NEXTAUTH_URL}/api/cron/expire-subscriptions
#
# 2. Notificaciones de vencimiento (diario a las 10:00 AM)  
# 0 10 * * * curl -X POST -H "Authorization: Bearer ${CRON_SECRET}" ${NEXTAUTH_URL}/api/cron/notify-subscriptions
#
# 3. Reporte de salud (semanal, lunes a las 9:00 AM)
# 0 9 * * 1 curl -H "Authorization: Bearer ${ADMIN_SECRET}" ${NEXTAUTH_URL}/api/admin/subscription-health

# ===========================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ===========================================

# 1. Copia este archivo como .env.local
# 2. Actualiza todos los valores con tus credenciales reales
# 3. Asegúrate de que CRON_SECRET y ADMIN_SECRET sean fuertes y únicos
# 4. Configura los cron jobs en tu servidor de producción
# 5. Prueba los endpoints manualmente antes de automatizar

# IMPORTANTE: 
# - Nunca commits este archivo con valores reales
# - Usa variables de entorno en producción
# - Rota las claves secretas periódicamente